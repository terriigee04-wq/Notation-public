# Notation Configuration
# Copy this file to .env and fill in your values

# Slack Bot Integration
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Optional: Slack channels for auto-posting
SLACK_CHANNEL_STATUS=#status
SLACK_CHANNEL_RISKS=#risks
SLACK_CHANNEL_DECISIONS=#decisions

# Node Environment
NODE_ENV=development

# Server Config (for future cloud deployment)
PORT=3000
HOST=localhost

# Database (optional, future use)
DATABASE_URL=postgresql://user:password@localhost/notation

# Stripe (for Pro tier payments)
STRIPE_PUBLIC_KEY=pk_live_your-public-key
STRIPE_SECRET_KEY=sk_live_your-secret-key

# Analytics (optional)
ANALYTICS_ID=your-google-analytics-id
